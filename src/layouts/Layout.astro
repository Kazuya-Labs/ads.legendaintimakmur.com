---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
}

import "../styles/global.css";

const {
  title,
  description,
  image = "/og-image.png",
  canonicalURL = Astro.url.href,
} = Astro.props;

const absoluteImageUrl = new URL(image, Astro.url.origin).href;
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <!-- Keamanan & Teknis Dasar -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon & Icons Resmi -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Legenda Inti Makmur" />

    <!-- SEO Utama -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="PT Legenda Inti Makmur, Nagata, alat kebersihan, perabotan plastik, pabrik plastik Banyumas, solusi kebersihan rumah"
    />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImageUrl} />
    <meta property="og:image:alt" content={`Gambar pratinjau untuk ${title}`} />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="PT Legenda Inti Makmur" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImageUrl} />

    <!-- ======================================================== -->
    <!-- AUDIT PRODUCTION-READY: SKRIP GLOBAL DIKENDALIKAN ASTRO -->
    <!-- ======================================================== -->
    <script>
      // Buat interface pendukung agar kompatibel dengan TypeScript Astro
      interface CustomWindow extends Window {
        fbq?: any;
        _fbq?: any;
        hasPageViewFired?: boolean;
      }
      const w = window as unknown as CustomWindow;

      // 1. INJEKSI UTAMA DENGAN URL CDN KONEKSI RESMI FACEBOOK
      if (!w.fbq) {
        w.fbq = function (...args: any[]) {
          w.fbq.callMethod ? w.fbq.callMethod(...args) : w.fbq.queue.push(args);
        };
        if (!w._fbq) w._fbq = w.fbq;
        w.fbq.push = w.fbq;
        w.fbq.loaded = true;
        w.fbq.version = "2.0";
        w.fbq.queue = [];

        const t = document.createElement("script");
        t.async = true;
        t.src = "https://connect.facebook.net/en_US/fbevents.js";
        const s = document.getElementsByTagName("script")[0];
        s.parentNode?.insertBefore(t, s);
      }

      // 2. KONFIGURASI AWAL PIXEL (URUTAN WAJIB AMAN)
      w.fbq("init", "1648898149501656");

      // FIX 1: Matikan sensor otomatis Meta SEBELUM memicu PageView pertama
      w.fbq("set", "autoConfig", false, "1648898149501656");

      // FIX 2: Jalankan PageView manual (Hanya 1 kali saja dengan pengunci Boolean)
      if (!w.hasPageViewFired) {
        w.fbq("track", "PageView");
        w.hasPageViewFired = true;
      }

      // 3. DETEKSI EVENT KLIK DATA-PIXEL-EVENT (MENDUKUNG VIEW TRANSITIONS ASTRO)
      function inisialisasiPixelTracker() {
        const elemenTerlacak = document.querySelectorAll("[data-pixel-event]");
        elemenTerlacak.forEach((elemen) => {
          elemen.removeEventListener("click", kirimEventPixel);
          elemen.addEventListener("click", kirimEventPixel);
        });
      }

      function kirimEventPixel(e: Event) {
        const targetElemen = (e.target as HTMLElement).closest(
          "[data-pixel-event]",
        );
        if (!targetElemen) return;

        const eventName = targetElemen.getAttribute("data-pixel-event");

        if (typeof w.fbq === "function" && eventName) {
          const contentName =
            targetElemen.getAttribute("data-pixel-name") || "";

          // Daftar Event Standar Meta Anda
          const daftarEventStandar = ["Contact", "Lead"];

          if (daftarEventStandar.includes(eventName)) {
            w.fbq("track", eventName, { content_name: contentName });
          } else {
            w.fbq("trackCustom", eventName, {
              button_name: contentName,
              target_anchor: targetElemen.getAttribute("href") || "",
            });
          }
        }
      }

      // Jalankan otomatis pada siklus muat halaman Astro
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", inisialisasiPixelTracker);
      } else {
        inisialisasiPixelTracker();
      }

      document.addEventListener("astro:page-load", inisialisasiPixelTracker);
    </script>

    <!-- FIXED: Menggunakan endpoint noscript dengan parameter pelacakan Meta resmi -->
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src="https://www.facebook.com/tr?id=1648898149501656&ev=PageView&noscript=1"
      />
    </noscript>
  </head>

  <body
    class="bg-slate-50 font-sans text-slate-800 antialiased min-h-screen flex flex-col"
  >
    <main class="flex-grow pt-20">
      <slot />
    </main>

    <!-- ======================================================== -->
    <!-- INTEGRASI ANIMASI COUNTER AMAN (INTERSECTION OBSERVER) -->
    <!-- ======================================================== -->
    <script is:inline>
      function jalankanAnimasiCounter() {
        const counterEl = document.getElementById("counter-trigger");
        if (!counterEl) return;

        const target = parseInt(
          counterEl.getAttribute("data-target") || "200",
          10,
        );
        const duration = parseInt(
          counterEl.getAttribute("data-duration") || "1800",
          10,
        );

        let hasAnimated = false;

        function startCountUp() {
          let startTime = null;
          const startValue = 1;

          function updateNumber(timestamp) {
            if (!startTime) startTime = timestamp;
            const elapsed = timestamp - startTime;
            const progress = Math.min(elapsed / duration, 1);

            const easeOutQuad = progress * (2 - progress);
            const currentValue = Math.floor(
              easeOutQuad * (target - startValue) + startValue,
            );

            counterEl.textContent = currentValue.toLocaleString("id-ID");

            if (elapsed < duration) {
              requestAnimationFrame(updateNumber);
            } else {
              counterEl.textContent = target.toLocaleString("id-ID");
            }
          }
          requestAnimationFrame(updateNumber);
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting && !hasAnimated) {
                hasAnimated = true;
                startCountUp();
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.2 },
        );

        observer.observe(counterEl);
      }

      document.addEventListener("DOMContentLoaded", jalankanAnimasiCounter);
      document.addEventListener("astro:page-load", jalankanAnimasiCounter);
    </script>
  </body>
</html>
