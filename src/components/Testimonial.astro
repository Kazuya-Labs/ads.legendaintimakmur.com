
---
import { Icon } from 'astro-icon/components';

// DATA TESTIMONIAL YANG REALISTIS & AMAT TERPERCAYA DI MATA PEMBELI GROSIR TRADISIONAL / ONLINE
const testimonials = [
  {
    name: "H. Budi Santoso",
    role: "Pemilik Toko Perabot Grosir",
    company: "Pelanggan Cargo Luar Jawa",
    comment: "Awalnya ragu transfer besar untuk kirim ke luar pulau. Ternyata barang dipacking aman banget pakai karung double dan dus lapis tebal. Alat pel dan keset catur aman sampai tujuan tanpa cacat. Margin keuntungan toko saya naik sejak ambil dari tangan pertama.",
    avatar: "/images/avatar-budi.webp" 
  },
  {
    name: "Ibu Siti Rahmawati",
    role: "Agen Lapak Pasar & Grosir Kelontong",
    company: "Pelanggan Dropping Rutin Banyumas",
    comment: "Sangat terbantu dengan sistem dropping langsung ke toko. Stok pel karet, sikat, dan sapu di lapak saya selalu aman, tidak pernah putus dari gudang pusat Pekuncen. Kalau ada barang pecah saat pengantaran, adminnya responsif langsung diganti baru.",
    avatar: "/images/avatar-siti.webp"
  },
  {
    name: "Hendra Wijaya",
    role: "Owner Olshop Perabot Unik",
    company: "Pelanggan Grosir Volume Jakarta",
    comment: "Sistem update stok hariannya sangat transparan di grup WhatsApp. Untuk kebutuhan reseller online seperti saya, kontinuitas stok barang unik rumah tangga di sini sangat aman. Klaim after sales-nya tidak berbelit-belit.",
    avatar: "/images/avatar-hendra.webp"
  }
];
---

<section id="testimonial" class="bg-slate-50 py-20 lg:py-28 border-b border-slate-200/60">
  <div class="mx-auto max-w-7xl px-6">
    
    <!-- Header Section: Menggunakan bahasa yang membumi -->
    <div class="text-center max-w-3xl mx-auto">
      <span class="text-xs font-bold tracking-wider text-blue-600 uppercase bg-blue-50 px-3 py-1.5 rounded-full">
        Kata Mitra Kami
      </span>
      <h2 class="mt-4 text-3xl font-black tracking-tight text-slate-900 sm:text-4xl">
        Dipercaya oleh Pemilik Toko & Agen Grosir Daerah
      </h2>
      <p class="mt-2 text-sm text-slate-500 max-w-xl mx-auto leading-relaxed">
        Ulasan jujur langsung dari para pelaku usaha yang telah mempercayakan pasokan tokonya kepada kami.
      </p>
    </div>

    <!-- Grid Testimonial -->
    <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((item) => (
        <div class="flex flex-col justify-between rounded-2xl border border-slate-200/60 bg-white p-8 shadow-sm transition-all duration-300 hover:shadow-xl relative group">
          
          <!-- Dekorasi Tanda Kutip Halus -->
          <span class="absolute top-6 right-8 text-6xl text-slate-100 font-serif pointer-events-none select-none" aria-hidden="true">“</span>

          <div>
            <!-- Rating Bintang -->
            <div class="flex items-center text-amber-400" aria-hidden="true">
              {Array.from({ length: 5 }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
                  <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
                </svg>
              ))}
            </div>
            <span class="sr-only">Penilaian 5 dari 5 bintang</span>

            <!-- Teks Testimonial: Menghapus tanda kutip ganda karena sudah ada hiasan quote -->
            <blockquote class="mt-4 text-xs sm:text-sm leading-relaxed text-slate-600 font-medium italic relative z-10">
              {item.comment}
            </blockquote>
          </div>

          <!-- Profil Klien -->
          <div class="mt-8 flex items-center gap-4 border-t border-slate-100 pt-5">
            
            <!-- Avatar Profil Klien -->
            <img 
              src={item.avatar} 
              alt={`Foto profil ${item.name}`}
              class="h-11 w-11 shrink-0 rounded-full object-cover bg-slate-100 border border-slate-200 shadow-sm"
              loading="lazy"
            />

            <div>
              <h3 class="font-bold text-sm text-slate-900 leading-tight">
                {item.name}
              </h3>
              <p class="mt-0.5 text-[10px] font-bold text-slate-400 uppercase tracking-wider">
                {item.role}
              </p>
              <p class="text-xs font-semibold text-blue-600 mt-0.5">
                {item.company}
              </p>
            </div>

          </div>

        </div>
      ))}
    </div>

    <!-- BOTTOM CTA CLOSING -->
    <div class="mt-16 text-center bg-white border border-slate-200/80 rounded-2xl p-8 max-w-3xl mx-auto shadow-sm group hover:border-blue-500 transition-all duration-300">
      <h3 class="text-lg font-black text-slate-900 transition-colors group-hover:text-blue-600">Siap bergabung dengan ratusan mitra bisnis kami?</h3>
      <p class="text-xs text-slate-500 mt-1">Dapatkan estimasi harga grosir khusus dan brosur katalog untuk wilayah distribusi Anda sekarang.</p>
      <div class="mt-5">
        <a 
          href="#kontak" 
          class="inline-block w-full sm:w-auto bg-emerald-600 text-white font-bold text-sm px-6 py-3.5 rounded-xl hover:bg-emerald-700 shadow-md shadow-emerald-600/10 transition-all duration-300 hover:-translate-y-0.5"
        >
          Mulai Diskusi Kemitraan via WhatsApp
        </a>
      </div>
    </div>

  </div>
</section>

