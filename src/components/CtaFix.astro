---
// Komponen Floating WhatsApp Button - Menggunakan Aset Lokal public/whatsapp.svg
const whatsappNumber = "6282221155363"; // Ganti dengan nomor WA perusahaan Anda (awali dengan 62)
const defaultMessage = encodeURIComponent("Halo Sales PT Legenda Inti Makmur, saya tertarik untuk bermitra dan ingin meminta Katalog Harga Grosir terbaru. Bisa dibantu?");
const waUrl = `https://wa.me/${whatsappNumber}?text=${defaultMessage}`;
---

<a
  href={waUrl}
  target="_blank"
  rel="noopener noreferrer"
  data-pixel="Contact"
  id="floating-wa"
  class="fixed bottom-6 right-6 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-emerald-500 text-white shadow-xl transition-all duration-300 hover:bg-emerald-600 hover:scale-110 focus:outline-none focus:ring-4 focus:ring-emerald-200 invisible opacity-0 translate-y-4"
  aria-label="Hubungi Sales via WhatsApp"
>
  <img 
    src="/whatsapp.svg" 
    alt="WhatsApp Icon" 
    class="h-7 w-7 object-contain brightness-0 invert" 
    loading="eager"
  />
  
  <span class="absolute -top-1 -right-1 flex h-3 w-3">
    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
    <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-400"></span>
  </span>
</a>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const waButton = document.getElementById("floating-wa");
    if (!waButton) return;

    // Eksekusi penundaan waktu 3 detik setelah halaman terbuka sempurna
    setTimeout(() => {
      waButton.classList.remove("invisible", "opacity-0", "translate-y-4");
      waButton.classList.add("opacity-100", "translate-y-0");
    }, 3000); 
  });
</script>
