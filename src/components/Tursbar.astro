
---
import { Icon } from "astro-icon/components";

// 1. DATA TARGET DISTRIBUSI (Teks diselaraskan agar ramah reseller & toko kelontong)
const distribusi = [
  { name: "Toko Perabot & Kelontong", icon: "mdi:storefront" },
  { name: "Agen & Grosir Luar Pulau", icon: "mdi:truck-delivery" },
  { name: "Reseller & Pemilik Olshop", icon: "mdi:cellphone" },
  { name: "Tender & Pengadaan Instansi", icon: "mdi:file-document-box-check" },
  { name: "Perlengkapan Kebersihan Komersial", icon: "mdi:broom" },
];

// 2. DATA KATEGORI PRODUK UTAMA DENGAN PATH GAMBAR RIIL YANG SUDAH ANDA UPDATE
const categories = [
  {
    title: "Cleaning Equipment",
    subtitle: "Alat Kebersihan Rumah & Industri",
    description: "Aneka model alat pel lantai (pel karet, pel putar), sikat toilet, dan sapu dengan durabilitas tinggi untuk supply toko ritel maupun vendor cleaning service.",
    image: "/pelLegendaIntiMakmurnew.jpg",
  },
  {
    title: "Cakar Taman",
    subtitle: "Tekstil Kebersihan Rumah Tangga",
    description: "Cakar Taman multifungsi berbahan plastik kokoh untuk mengumpulkan sampah daun atau menggemburkan tanah dengan mudah.",
    // description: "Keset kaki anyaman catur, keset karakter anti-slip, dan kain lap microfiber berkualitas tinggi. Produk wajib dengan perputaran omset harian yang sangat cepat.",
    image: "/cakarNew.jpg", 
  },
  {
    title: "Houseware & Barang Unik",
    subtitle: "Perabot Praktis & Pernak-Pernik Inovatif",
    description: "Peralatan rumah tangga fungsional, gantungan baju, rak bumbu minimalis, dan perabot unik yang selalu viral di media sosial.",
    image: "/gantunganBaju.jpg", 
  },
  {
    title: "Gagang Stick Handle Perlengkapan Pengrajin Sapu,Pel Dan Kebutuhan lain yang menggunakan gagang fiber PVC",
    subtitle: "Wadah & Kontainer Rumah Tangga",
    description :"Kami melayani Partai besar dan industri kecil para pengrajin sapu,pel lantai, sikat dorong,wiper air,garuk daun yang menggunakan stik, tongkat Handel gagang pipa fiber PVC untuk pegangan kualitas kuat tebal,tahan air anti karat dan anti penyok, keras lurus anti bengkok ",
    image: "/tumpukan-ember.jpg",
  },
];
---

<!-- SECTION 1: TARGET DISTRIBUSI & AJAKAN GABUNG -->
<section class="bg-slate-50 py-16 border-b border-slate-200/60">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-blue-600">
        Peluang Bisnis Grosir
      </p>
      <h2 class="mt-3 text-2xl sm:text-3xl font-black text-slate-900 tracking-tight leading-snug">
        Punya Penghasilan Bukan Sekadar Mimpi!<br class="hidden sm:inline"/> 
        Bergabunglah Menjadi Mitra Distribusi <span class="text-blue-600">Legenda Inti Makmur</span>.
      </h2>
    </div>

    <!-- Layout Grid Jaringan Mitra -->
    <div class="mt-12 grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3 lg:grid-cols-5 justify-center">
      {distribusi.map((partner) => (
        <div class="flex flex-col items-center justify-center p-5 bg-white border border-slate-100 rounded-xl shadow-sm text-center group hover:border-blue-500 hover:shadow-md transition-all duration-300">
          <div class="p-3 bg-blue-50 rounded-lg text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300 mb-3">
            <Icon name={partner.icon} class="h-6 w-6"/>
          </div>
          <span class="text-xs sm:text-sm font-bold text-slate-800 leading-tight">
            {partner.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SECTION 2: KATEGORI PRODUK -->
<section id="produk" class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center md:text-left max-w-3xl mb-16">
      <span class="text-xs font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-3 py-1.5 rounded-full">
        Kapasitas Suplai Besar
      </span>
      <h2 class="mt-4 text-3xl sm:text-4xl font-black leading-tight text-slate-900 tracking-tight">
        Kategori Produk Utama Untuk Kebutuhan Bisnis & Pengadaan
      </h2>
    </div>

    <!-- Layout Grid Kartu Produk -->
    <div class="grid gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((cat) => (
        <article class="group overflow-hidden rounded-2xl border border-slate-200/60 bg-white shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between">
          <div>
            <!-- Container Gambar Realistis -->
            <div class="aspect-[4/3] bg-slate-100 overflow-hidden relative border-b border-slate-100">
              <img 
                src={cat.image} 
                alt={`Grosir ${cat.title}`}
                class="w-full h-full object-cover transform group-hover:scale-105 transition duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>

            <div class="p-6">
              <p class="text-[10px] font-bold uppercase tracking-wider text-blue-600 mb-1">
                {cat.subtitle}
              </p>
              <h3 class="text-xl transform capitalize font-bold text-slate-900 group-hover:text-blue-600 transition-colors">
                {cat.title}
              </h3>
              <p class="mt-3 text-xs leading-relaxed text-slate-500 font-medium">
                {cat.description}
              </p>
            </div>
          </div>

          <!-- 
            OPTIMASI INTEGRASI PIXEL:
            Menyisipkan atribut data-pixel-event dan data-pixel-name secara dinamis sesuai nama kategori.
            Ketika tombol diklik, sistem otomatis mencatat kategori barang mana yang paling diminati pembeli.
          -->
          <div class="p-6 pt-0">
            <a
              href="#kontak"
              data-pixel-event="clickInternalNav"
              data-pixel-name={`Katalog ${cat.title}`}
              class="inline-flex items-center gap-2 text-xs font-bold text-blue-600 hover:text-blue-800 transition-colors group/link"
            >
              Minta Daftar Harga & MOQ 
              <span class="transform group-hover/link:translate-x-1 transition-transform duration-200">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

