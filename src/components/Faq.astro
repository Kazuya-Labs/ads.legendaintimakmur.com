
---
// DATA FAQ REALISTIS & SESUAI DENGAN ALUR OPERASIONAL LEGENDA INTI MAKMUR
const faqs = [
  {
    id: "faq-1",
    q: "Berapa minimal order (MOQ) untuk belanja grosir di sini?",
    a: "Sebagai supplier tangan pertama, kami memberikan minimum order yang sangat ramah bagi toko retail, pasar, maupun reseller. Pembelian tidak harus berskala kontainer. Untuk detail minimal order per dus atau per bal tiap jenis barang, silakan langsung hubungi admin kami."
  },
  {
    id: "faq-2",
    q: "Bagaimana sistem pengiriman untuk wilayah Banyumas dan luar pulau?",
    a: "Untuk wilayah karesidenan Banyumas (Pekuncen, Ajibarang, Purwokerto, dll), kami melayani pengantaran langsung via armada dropping internal kami. Sedangkan untuk luar kota dan luar pulau, barang dikirim via ekspedisi kargo darat/laut langganan dengan tarif paling hemat."
  },
  {
    id: "faq-3",
    q: "Apakah packing pengiriman ke luar kota/pulau dijamin aman?",
    a: "Sangat aman. Kami menerapkan standar packing khusus grosir menggunakan karung double berlapis tebal dan boks kardus yang diikat kuat. Hal ini untuk memastikan produk alat pel, keset, dan perabot plastik tidak pecah atau rusak selama proses perjalanan kargo."
  },
  {
    id: "faq-4",
    q: "Bagaimana cara melihat katalog produk terupdate dan daftar harganya?",
    a: "Anda bisa langsung menekan tombol Masuk Grup WhatsApp di halaman ini atau bergabung ke Saluran grosir resmi kami. Tim admin kami selalu mengupdate ketersediaan stok barang unik dan peralatan rumah tangga setiap hari secara transparan."
  }
];

// JSON-LD untuk optimasi SEO Google FAQ Rich Snippet otomatis
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<!-- Injeksi Schema SEO: Ditambahkan pembungkus fragment aman -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section id="faq" class="bg-white py-20 lg:py-28 border-t border-slate-100">
  <div class="mx-auto max-w-7xl px-6">
    
    <!-- Header Section -->
    <div class="max-w-3xl mb-12 lg:mb-16">
      <span class="text-xs font-bold tracking-wider text-blue-600 uppercase bg-blue-50 px-3 py-1.5 rounded-full">
        Pertanyaan Umum
      </span>
      <h2 class="mt-4 text-3xl font-black tracking-tight text-slate-900 sm:text-4xl">
        Punya Pertanyaan Seputar Grosir Kami?
      </h2>
      <p class="mt-2 text-sm text-slate-500 leading-relaxed">
        Berikut adalah rangkuman informasi yang paling sering ditanyakan oleh calon mitra toko dan reseller mengenai sistem kerja sama di Legenda Inti Makmur.
      </p>
    </div>

    <!-- Grid Layout Modifikasi -->
    <div class="grid gap-8 lg:grid-cols-3 items-stretch"> 
      
      <!-- Kolom FAQ (Mengambil 2 Kolom) -->
      <div class="lg:col-span-2 space-y-4">
        {faqs.map((item) => (
          <details class="group rounded-2xl border border-slate-200 p-5 transition-all duration-200 open:border-blue-300 open:bg-blue-50/20 open:shadow-sm">
            
            <summary class="flex cursor-pointer items-center justify-between gap-4 list-none text-base sm:text-lg font-bold text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 rounded-lg select-none">
              <span>{item.q}</span>
              
              <!-- Indikator Panah dengan Optimasi SVG Namespace Standar W3C -->
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-slate-100 text-slate-500 transition-transform duration-200 group-open:rotate-180 group-open:bg-blue-600 group-open:text-white" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="h-4 w-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </span>
            </summary>

            <p class="mt-4 text-xs sm:text-sm leading-relaxed text-slate-600 border-t border-slate-150 pt-4 font-medium">
              {item.a}
            </p>
            
          </details>
        ))}
      </div>

      <!-- Kolom CTA Kanan -->
      <div class="rounded-2xl bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 p-8 sm:p-10 text-white shadow-xl flex flex-col justify-between border border-slate-800">
        <div class="my-auto py-4"> 
          <span class="text-xs font-bold tracking-widest text-blue-400 uppercase">
            Hubungi Admin Grosir
          </span>
          
          <h3 class="mt-3 text-2xl font-black leading-tight tracking-tight sm:text-3xl">
            Butuh Informasi Lebih Spesifik?
          </h3>
          
          <p class="mt-4 text-xs sm:text-sm leading-relaxed text-slate-300 font-normal">
            Tim admin sales kami siap membantu menghitung estimasi biaya pengiriman kargo termurah ke wilayah Anda, mengecek ketersediaan stok gudang hari ini, serta membantu proses join ke grup grosir WhatsApp.
          </p>
        </div>

        <div class="mt-8 space-y-3">
          <!-- 
            OPTIMASI PIXEL: 
            Mengubah event 'ViewContent' menjadi 'Contact' (Atau 'FindLocation') karena tombol ini melakukan aksi melompat ke section kontak/chat.
          -->
          <a
            data-pixel-event="Contact"
            data-pixel-name="Tanya Admin FAQ"
            href="#kontak"
            class="block w-full rounded-xl bg-amber-500 py-3.5 text-center text-sm font-bold text-slate-900 shadow-md shadow-amber-500/10 transition-all duration-300 hover:bg-amber-400 hover:scale-[1.01]"
          >
            Tanya Admin via WhatsApp
          </a>
          
          <!-- 
            OPTIMASI GRUP LINK:
            Menambahkan rel="noopener noreferrer" demi keamanan performa saat membuka tab eksternal link WhatsApp Group.
          -->
          <a
            href="https://chat.whatsapp.com/Bufz5pOsRZsJEAlmZYH0nT?mode=gi"
            data-pixel-event="Contact"
            data-pixel-name="Join Grup WA FAQ"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full rounded-xl border border-slate-700 bg-white/5 py-3.5 text-center text-sm font-semibold text-white transition-all duration-300 hover:bg-white/10"
          >
            Masuk Grup WhatsApp   
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  summary {
    list-style: none;
  }
  summary::-webkit-details-marker {
    display: none;
  }
</style>

