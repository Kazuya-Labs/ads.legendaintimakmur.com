
---
import { Icon } from "astro-icon/components";
import Video from './ui/Video.astro'

// DATA ANGKA REKAM JEJAK (STATISTIK UTAMA)
const stats = [
  { value: "10+", label: "Kota Dropping Rutin", sub: "Jawa Tengah & Sekitarnya" },
  { box: "5.000+", label: "Produk Terkirim / Bulan", sub: "Skala Nasional & Lokal" },
  { box: "100%", label: "Real Gudang & Fisik", sub: "Bukan Dropshipper Tangan Ke-2" },
];

// DATA AKTIVITAS LOGISTIK UTAMA (DITAMPILKAN DALAM CARD KANAN)
const logistik = [
  // {
  //   title: "Dropping Armada Lokal Harian",
  //   wilayah: "Banyumas, Pekuncen, Ajibarang & Sekitarnya",
  //   desc: "Distribusi terjadwal langsung ke depan toko ritel dan warung kelontong mitra menggunakan armada pikap internal.",
  //   badge: "Dropping Langsung",
  //   image : '/bukti-kirim.png'
  // },
  {
    title: "Ekspedisi Cargo Luar Pulau",
    wilayah: "Sumatera, Kalimantan, Sulawesi hingga NTT",
    desc: "Pengiriman partai besar menggunakan kargo langganan termurah dengan standar keamanan packing karung berlapis tebal.",
    badge: "Kargo Nasional",
    video : 'https://files.catbox.moe/r5u6mf.mp4'
  }
];
---

<section id="rekam-jejak" class="bg-slate-900 text-white py-24 border-t border-slate-800">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-16 lg:grid-cols-12 items-center">
      
      <!-- SISI KIRI: STATISTIK & REPUTASI GUDANG -->
      <div class="lg:col-span-5 space-y-8">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-blue-400 bg-blue-500/10 px-3 py-1.5 rounded-full border border-blue-500/20">
            Rekam Jejak Logistik
          </span>
          <h2 class="mt-4 text-3xl sm:text-4xl font-black tracking-tight leading-tight">
            Distribusi Nyata Dari <span class="text-blue-400">Pekuncen</span> Ke Seluruh Nusantara
          </h2>
          <p class="mt-4 text-sm leading-relaxed text-slate-400">
            Kami mengelola rantai pasok dengan transparan. Setiap bulan, ribuan unit alat kebersihan, keset, dan perabot unik bergerak dari gudang utama kami untuk mengisi etalase toko retail hingga agen besar.
          </p>
        </div>

        <!-- Grid Angka Statistik -->
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 lg:grid-cols-1">
          {stats.map((item) => (
            <div class="flex items-center gap-4 p-4 bg-slate-800/40 border border-slate-800 rounded-xl">
              <div class="text-2xl sm:text-3xl font-black text-blue-400 font-mono shrink-0">
                {item.value || item.box}
              </div>
              <div class="border-l border-slate-700 pl-4">
                <h4 class="text-xs sm:text-sm font-bold text-slate-200 leading-tight">{item.label}</h4>
                <p class="text-[11px] text-slate-500 mt-0.5">{item.sub}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="pt-2">
          <a 
            href="#kontak" 
            data-pixel-event="ClickInternalNav"
            data-pixel-name="Cek Jangkauan Wilayah"
            class="inline-flex items-center gap-2 text-xs font-bold text-white bg-blue-600 hover:bg-blue-700 px-5 py-3 rounded-xl transition-all shadow-lg shadow-blue-600/10 group"
          >
            Cek Jangkauan Pengiriman Wilayah Anda
            <Icon name="mdi:arrow-right" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform" />
          </a>
        </div>
      </div>

      <!-- SISI KANAN: KELAYAKAN PROSES LOGISTIK (VISUAL PROOF) -->
      <div class="lg:col-span-7 grid gap-6 sm:grid-cols-1">
        {logistik.map((log) => (
          <div class="bg-slate-800/60 border border-slate-800 rounded-2xl p-6 flex flex-col justify-between hover:border-slate-700 transition-all group">
            <div>
              <!-- Container Gambar/Video Pendukung Logistik -->
              <div class="aspect-[16/10] bg-slate-950 rounded-xl overflow-hidden mb-5 relative flex items-center justify-center border border-slate-800">
                <span class="absolute z-10 top-3 left-3 text-[10px] font-bold bg-blue-500 text-white px-2 py-0.5 rounded-md uppercase tracking-wider">
                  {log.badge}
                </span>
                
                {log.image ? (
                  <img 
                    src={log.image} 
                    alt={`Bukti operasional ${log.title}`}
                    class="w-full h-full absolute inset-0 object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full absolute inset-0 transition-transform duration-500 group-hover:scale-105">
                <Video src={log.video} />
                  </div>
                )}
              </div>

              <h3 class="text-lg font-bold text-slate-100 leading-snug group-hover:text-blue-400 transition-colors">
                {log.title}
              </h3>
              <div class="mt-1.5 flex items-start gap-1 text-[11px] text-slate-400 font-medium">
                <Icon name="mdi:map-marker" class="h-3.5 w-3.5 text-red-400 shrink-0 mt-0.5" />
                <span>{log.wilayah}</span>
              </div>
              <p class="mt-4 text-xs leading-relaxed text-slate-400">
                {log.desc}
              </p>
            </div>

            <div class="mt-6 pt-4 border-t border-slate-800/80 flex items-center justify-between text-[11px] text-slate-500 font-medium">
              <span>Status Operasional</span>
              <span class="flex items-center gap-1.5 text-emerald-400">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                Rutin & Aktif
              </span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

