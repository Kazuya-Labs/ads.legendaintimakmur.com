
---
import { Icon } from 'astro-icon/components';

// REFAKTOR DATA: Menyelaraskan nama & ID target lompatan menu sesuai dengan komponen riil kita
const menus = [
  { name: "Beranda", href: "#hero" },
  { name: "Produk", href: "#produk" },
  { name: "Rekam Jejak", href: "#rekam-jejak" }, // Mengubah portfolio menjadi rekam-jejak
  { name: "FAQ", href: "#faq" },
  { name: "Kontak", href: "#kontak" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur-xl transition-all duration-300"
>
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6">

    <!-- LOGO UTAMA: Menggunakan kombinasi andalan Anda yang terbukti presisi -->
    <a href="#hero" class="flex items-center gap-3 group focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-700 rounded-lg" aria-label="PT Legenda Inti Makmur - Kembali ke Beranda">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-blue-700 to-blue-900 text-white shadow-md">
        <!-- Struktur Gambar Asli Anda (Dioptimalkan ke loading="eager" agar langsung muncul tanpa delay) -->
        <img 
          src="/og-image.jpg" 
          alt="Logo resmi Legenda Inti Makmur" 
          loading="eager"
          class="rounded-full w-full h-full object-contain"
        />
      </div>

      <div>
        <span class="block text-lg font-black tracking-tight text-slate-900">
          LEGENDA
        </span>
        <span class="block -mt-1 text-xs font-bold tracking-[0.18em] text-slate-600">
          INTI MAKMUR
        </span>
      </div>
    </a>

    <!-- Desktop Navigation Menu -->
    <nav class="hidden items-center gap-8 lg:flex" aria-label="Navigasi Utama">
      {
        menus.map((menu) => (
          <a
            href={menu.href}
            class="text-[15px] font-semibold text-slate-700 transition hover:text-blue-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-700 rounded"
          >
            {menu.name}
          </a>
        ))
      }
    </nav>

    <!-- Right CTA (Desktop View) -->
    <div class="hidden items-center gap-6 lg:flex">
      <!-- KOREKSI DATA TLP: Menyelaraskan nilai href dan teks agar menggunakan nomor resmi yang sama -->
      <a
        href="tel:+6282221155363"
        class="text-[15px] font-bold text-slate-700 transition hover:text-blue-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-700 rounded flex items-center gap-1.5"
        aria-label="Hubungi kami melalui telepon di +62 822 2115 5363"
      >
        <Icon name="mdi:phone" class="w-4 h-4 text-slate-400" />
        0822-2115-5363 
      </a>

      <!-- OPTIMASI PIXEL: Menyisipkan atribut pelacak otomatis 'data-pixel-event' -->
      <a
        href="#kontak"
        data-pixel-event="Contact"
        data-pixel-name="Klik Minta Penawaran Navbar Desktop"
        class="rounded-xl bg-blue-700 px-6 py-3 font-bold text-white text-sm shadow-md transition duration-200 hover:bg-blue-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-700"
      >
        Minta Penawaran
      </a>
    </div>

    <!-- Mobile Menu Button Controls -->
    <button
      id="mobile-menu-btn"
      class="rounded-xl border border-slate-300 p-2.5 lg:hidden text-slate-700 hover:bg-slate-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-700"
      aria-label="Buka menu navigasi"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

  </div>

  <!-- Mobile Menu Layout -->
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-200 bg-white lg:hidden animate-fade-in"
    aria-label="Navigasi Mobile"
  >
    <nav class="flex flex-col p-6 divide-y divide-slate-100">
      {
        menus.map((menu) => (
          <a
            href={menu.href}
            class="py-4 text-base font-bold text-slate-700 hover:text-blue-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-700"
          >
            {menu.name}
          </a>
        ))
      }

      <div class="pt-6">
        <!-- OPTIMASI PIXEL MOBILE: Menyisipkan pemicu event pelacak pada tombol mobile -->
        <a
          href="#kontak"
          data-pixel-event="Contact"
          data-pixel-name="Klik Minta Penawaran Navbar Mobile"
          class="block w-full rounded-xl bg-blue-700 py-4 text-center font-bold text-white hover:bg-blue-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-700"
        >
          Minta Penawaran
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- SCRIPT OPERASIONAL NAVIGASI MOBILE (INLINE) -->
<script is:inline>
  function inisialisasiMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const links = menu?.querySelectorAll('nav a');

    if (!btn || !menu) return;

    // Fungsi buka tutup menu mobile
    btn.addEventListener("click", () => {
      const isExpanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", !isExpanded);
      btn.setAttribute("aria-label", isExpanded ? "Buka menu navigasi" : "Tutup menu navigasi");
      menu.classList.toggle("hidden");
    });

    // Menutup menu mobile otomatis jika salah satu tautan menu diklik oleh user
    links?.forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
        btn.setAttribute("aria-label", "Buka menu navigasi");
      });
    });

    // Menutup menu mobile otomatis via tombol Escape keyboard
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !menu.classList.contains("hidden")) {
        menu.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
        btn.setAttribute("aria-label", "Buka menu navigasi");
        btn.focus();
      }
    });
  }

  // Jalankan skrip saat siklus muat halaman Astro selesai
  document.addEventListener("DOMContentLoaded", inisialisasiMobileMenu);
  document.addEventListener("astro:page-load", inisialisasiMobileMenu);
</script>

